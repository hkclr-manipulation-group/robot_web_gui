<?xml version="1.0"?>
<robot name="simple6dof">
  <material name="dark"><color rgba="0.18 0.24 0.36 1"/></material>
  <material name="blue"><color rgba="0.42 0.64 0.95 1"/></material>
  <material name="light"><color rgba="0.85 0.88 0.94 1"/></material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.24 0.24 0.1"/></geometry>
      <material name="dark"/>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.30"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="30" velocity="2"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.175" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.35"/></geometry>
      <material name="light"/>
    </visual>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.30" rpy="0 1.57079632679 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.4" upper="2.4" effort="30" velocity="2"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry><box size="0.07 0.07 0.32"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4" upper="2.4" effort="30" velocity="2"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.24"/></geometry>
      <material name="light"/>
    </visual>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.32" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.028" length="0.20"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.24" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2"/>
  </joint>

  <link name="link6">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.16"/></geometry>
      <material name="light"/>
    </visual>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2"/>
  </joint>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="tool_joint" type="fixed">
    <parent link="link6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>
</robot>
